# ── Anthropic API Key ─────────────────────────────────────────────────────────
# Required for the self-hosted version.
# Get your key at: https://console.anthropic.com/keys
# IMPORTANT: This key is used directly from the browser (client-side).
# Do not commit your real .env file. This file is safe to commit.

VITE_ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Tracker endpoint (for generated reporters & handshake files) ───────────────
# Used in Prep/Push/Pull output and .tracker-config.json. Default if unset:
#   http://localhost:3000/api/project-update

VITE_TRACKER_URL=http://localhost:3000/api/project-update

# Optional: fixed agent key for X-Agent-Key in handshake/reporters.
# Must match on client (VITE_AGENT_KEY) and server (AGENT_KEY or VITE_AGENT_KEY).

VITE_AGENT_KEY=dev-agent-key

# ── Notes ─────────────────────────────────────────────────────────────────────
# The claude-artifact version does NOT need this key — it runs inside claude.ai
# which handles authentication automatically.
#
# For the self-hosted version, Anthropic requires the header:
#   "anthropic-dangerous-direct-browser-access": "true"
# This is already set in self-hosted/src/App.jsx.
#
# Token usage for both versions is identical per call.
# Self-hosted bills to your Anthropic API account.
# Artifact version bills to your Claude.ai subscription.
