{
  "name": "ai-project-tracker",
  "version": "1.0.0",
  "description": "AI-powered project tracker with Prep, Push, and Pull reporter agents",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "node server/index.js",
    "build": "vite build",
    "start": "NODE_ENV=production node server/index.js",
    "preview": "NODE_ENV=production node server/index.js",
    "test": "vitest run --config tests/vitest.config.js tests/unit",
    "test:security": "vitest run --config tests/vitest.config.js tests/security",
    "test:coverage": "vitest run --config tests/vitest.config.js --coverage",
    "test:ai": "vitest run --config tests/vitest.config.js tests/ai"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^14.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitest/coverage-v8": "^1.6.0",
    "concurrently": "^9.0.1",
    "jsdom": "^24.0.0",
    "supertest": "^7.0.0",
    "vite": "^5.0.0",
    "vitest": "^1.6.0"
  }
}
